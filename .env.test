# Test-specific environment overrides
# Loaded AFTER .env by the test harness — these values override defaults
# Uses localhost because tests run outside Docker, connecting to mapped ports
#
# If you changed port mappings in docker-compose.yml, update DB_PORT and
# REDIS_PORT below to match the left side (host side) of the mapping.

# Database — point to Docker-mapped ports on localhost
DB_HOST=localhost
DB_PORT=5434
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
DB_POOL_SIZE=5

# Redis — point to Docker-mapped ports on localhost
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=1

# Auth — test secrets (not production)
JWT_SECRET=test-jwt-secret-for-integration-tests
JWT_EXPIRY_HOURS=1
BCRYPT_COST=12

# Logging
ENV=test
